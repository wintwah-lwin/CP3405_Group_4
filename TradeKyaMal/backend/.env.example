# MongoDB
MONGODB_URI=mongodb://localhost:27017/tradekyamal

# CORS (frontend URL in production)
CORS_ORIGIN=http://localhost:3000

# TradingEconomics — only needed for economic calendar fetch
# Sign up: https://developer.tradingeconomics.com
TRADING_ECONOMICS_API_KEY=your_tradingeconomics_key_here

# Finviz Futures and Yahoo Sectors need NO API keys — they work automatically.

# Group repo evidence sync (after website fetch or macro pipeline)
# GitHub API push (production) OR local folder write (development)
GITHUB_TOKEN=your_github_personal_access_token
GITHUB_REPO=wintwah-lwin/CP3405_Group_4
LOCAL_GROUP_REPO_PATH=/path/to/CP3405_Group_4
EVIDENCE_WEEK=24
AUTO_SYNC_EVIDENCE=true

# Public URL for Python pipeline callback (optional, local dev uses localhost)
BACKEND_PUBLIC_URL=http://localhost:4000
